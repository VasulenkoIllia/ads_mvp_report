NODE_ENV=development
PORT=4010
CORS_ORIGIN=http://localhost:4010,http://localhost:5173
# docker-compose postgres (5434 -> container 5432)
DATABASE_URL=postgresql://ads_mvp_report:ads_mvp_report@localhost:5434/ads_mvp_report?schema=public

# Used by docker-compose.deploy.yml for db service
POSTGRES_DB=ads_mvp_report
POSTGRES_USER=ads_mvp_report
POSTGRES_PASSWORD=ads_mvp_report

# Access control: only these Google emails may login to the service
APP_ALLOWED_GOOGLE_EMAILS=owner@workflo.space
# Session lifetime (forced relogin)
APP_SESSION_TTL_DAYS=6
# Required in production for signing auth cookie
APP_SESSION_SECRET=change_me_to_long_random_secret
# Basic request throttling
RATE_LIMIT_AUTH_LOGIN_START_WINDOW_MS=60000
RATE_LIMIT_AUTH_LOGIN_START_MAX=20
RATE_LIMIT_WRITE_WINDOW_MS=60000
RATE_LIMIT_WRITE_MAX=30
DASHBOARD_ENABLED=true

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4010/api/v1/google/oauth/callback
GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/adwords https://www.googleapis.com/auth/spreadsheets https://www.googleapis.com/auth/userinfo.email openid
GOOGLE_OAUTH_STATE_TTL_MINUTES=15
GOOGLE_OAUTH_TOKEN_ALERT_DAYS=7
GOOGLE_OAUTH_TOKEN_ENCRYPTION_KEY=change_me_to_long_random_secret

GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_MANAGER_CUSTOMER_ID=
GOOGLE_ADS_API_VERSION=v21
GOOGLE_ADS_HTTP_TIMEOUT_MS=30000
GOOGLE_ADS_RETRY_ATTEMPTS=4
GOOGLE_ADS_RETRY_BASE_DELAY_MS=400

GOOGLE_SHEETS_REQUIRED_SCOPE=https://www.googleapis.com/auth/spreadsheets
GOOGLE_SHEETS_HTTP_TIMEOUT_MS=30000
GOOGLE_SHEETS_RETRY_ATTEMPTS=4
GOOGLE_SHEETS_RETRY_BASE_DELAY_MS=400
SHEETS_MANUAL_MAX_RANGE_DAYS=180

INGESTION_MAX_RANGE_DAYS=365
INGESTION_RUN_STALE_MINUTES=180
SHEETS_RUN_STALE_MINUTES=240

SCHEDULER_POLL_SECONDS=30
SCHEDULER_CATCHUP_DAYS=3
SCHEDULER_REFRESH_DAYS=2
SCHEDULER_INITIAL_DELAY_SECONDS=0
